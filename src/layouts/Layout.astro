---
import { NavBar } from '../components/NavBar.jsx';
import { Footer } from '../components/Footer.jsx';
import '../styles/global.scss';

// Derived from `site` in astro.config (driven by SITE_URL per environment).
const SITE_URL = (Astro.site?.href ?? 'https://www.associum.ai/').replace(/\/$/, '');

// Only production should be indexable. DEPLOY_ENV is set by CI; local builds
// default to production (indexable). Non-production builds (e.g. staging) get a
// site-wide noindex so they never compete with prod in search results.
const isProduction = (process.env.DEPLOY_ENV ?? 'production') === 'production';

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogImage = '/associo-og-home.jpg',
  ogImageAlt,
  ogType = 'website',
  ogSiteName = 'Associum',
  canonical,
  preloadImages = [],
  noindex = false,
} = Astro.props;

// Astro.url.pathname includes a trailing ".html" under build.format: 'file'
// (and a trailing slash under 'directory'). Normalize to a clean route path
// so the NavBar active-state comparison works in both modes.
const cleanPath =
  Astro.url.pathname.replace(/\.html$/, '').replace(/(.)\/$/, '$1') || '/';

const fullOgImage = ogImage?.startsWith('http') ? ogImage : `${SITE_URL}${ogImage}`;
const fullCanonical = canonical
  ? (canonical.startsWith('http') ? canonical : `${SITE_URL}${canonical}`)
  : null;
const ogUrl = fullCanonical ?? `${SITE_URL}${cleanPath === '/' ? '/' : cleanPath}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lato:wght@300;700&family=Space+Grotesk:wght@700&display=swap"
      rel="stylesheet"
    />

    {
      preloadImages.map((src) => (
        <link rel="preload" as="image" href={src} type="image/webp" />
      ))
    }

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=1.0.1" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=1.0.1" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=1.0.1" />
    <link rel="shortcut icon" href="/favicon.ico?v=1.0.1" />
    <link rel="manifest" href="/site.webmanifest?v=1.0.1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    {(noindex || !isProduction) && (
      <meta name="robots" content={isProduction ? 'noindex, follow' : 'noindex, nofollow'} />
    )}
    {fullCanonical && <link rel="canonical" href={fullCanonical} />}

    {/* Open Graph / Facebook */}
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:title" content={ogTitle || title} />
    <meta property="og:description" content={ogDescription || description} />
    <meta property="og:image" content={fullOgImage} />
    {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
    <meta property="og:site_name" content={ogSiteName} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={ogUrl} />
    <meta name="twitter:title" content={ogTitle || title} />
    <meta name="twitter:description" content={ogDescription || description} />
    <meta name="twitter:image" content={fullOgImage} />

  </head>
  <body>
    <NavBar client:load pathname={cleanPath} />
    <slot />
    <Footer />
  </body>
</html>
